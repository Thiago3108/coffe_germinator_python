# Copia este archivo a .env y completa los valores.
# .env NO debe subirse a Git (ver .gitignore).

# Token compartido con el ESP32 (debe coincidir con DEVICE_TOKEN en secrets.h)
# Generar uno largo: openssl rand -hex 32
API_TOKEN=cambia-este-token-por-uno-largo-y-secreto-de-64-chars

# Base de datos
DATABASE_URL=sqlite:///./germinador.db

# Orígenes permitidos por CORS, separados por coma.
# Para la app Android nativa NO se necesita CORS, pero si algún día
# añades un frontend web pon aquí sus orígenes.
CORS_ORIGINS=http://localhost,http://127.0.0.1

# Puerto
PORT=8001
